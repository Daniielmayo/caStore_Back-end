# ══════════════════════════════════════════════════════════════════════════════
#  ENTORNO DE DESARROLLO (Docker local)
#  Copiar como: .env.development
# ══════════════════════════════════════════════════════════════════════════════
PORT=4000
NODE_ENV=development

# Database — contenedor Docker local
DB_HOST=db
DB_PORT=3306
DB_NAME=sgia_dev
DB_USER=sgia_user
DB_PASSWORD=cambia_esto
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# Seguridad (mínimo 64 caracteres)
JWT_SECRET=cambia_esto_por_un_secret_de_minimo_64_caracteres_muy_seguro_xxxxxx
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Correo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@ejemplo.com
SMTP_PASS=tu_app_password
SMTP_FROM="SGIA Almacén <noreply@ejemplo.com>"

# App
FRONTEND_URL=http://localhost:3000


# ══════════════════════════════════════════════════════════════════════════════
#  ENTORNO DE PRODUCCIÓN (Render + Aiven)
#  Las variables marcadas con sync: false deben configurarse en el
#  Render Dashboard → Environment → Secret Files
# ══════════════════════════════════════════════════════════════════════════════
# NODE_ENV=production
# PORT=4000

# Database — Aiven MySQL (obtener desde Aiven Console → Service URI)
# DB_HOST=<servicio>.aivencloud.com
# DB_PORT=<puerto_aiven>           # Usualmente 3306 o un puerto personalizado
# DB_NAME=defaultdb
# DB_USER=avnadmin
# DB_PASSWORD=<password_aiven>
# DB_POOL_MIN=2
# DB_POOL_MAX=10
# DB_SSL=true                       # OBLIGATORIO en Aiven

# Seguridad (usar valor generado por Render o uno muy seguro)
# JWT_SECRET=<secret_produccion_minimo_64_caracteres>
# JWT_EXPIRES_IN=8h
# JWT_REFRESH_EXPIRES_IN=7d
# BCRYPT_ROUNDS=12

# Correo (mismas credenciales de SMTP o servicio de producción)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_correo@dominio.com
# SMTP_PASS=tu_app_password
# SMTP_FROM="SGIA <noreply@dominio.com>"

# App
# FRONTEND_URL=https://tu-frontend.vercel.app
